# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL ───────────────────────────────────────────
# Development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example:
# NEXT_PUBLIC_APP_URL=https://tgplus.jp

# ── Stripe TEST (development) ───────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...
STRIPE_SUPPORTER_PRICE_ID=price_...

# ── Stripe LIVE (production only — never mix with test) ─
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
# STRIPE_SUPPORTER_PRICE_ID_LIVE=price_...

# Fallback webhook secret (optional)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Platform fee rate (0.1 = 10%)
STRIPE_PLATFORM_FEE_RATE=0.1

# Allow test keys in production build (NOT for public launch)
# STRIPE_ALLOW_TEST_IN_PRODUCTION=true

# ── SEO (Google Search Console) ─────────────────────────
# GOOGLE_SITE_VERIFICATION=your-verification-code-from-search-console

# ── Development only ────────────────────────────────────
# ENABLE_TEST_POINT_PURCHASE=true
